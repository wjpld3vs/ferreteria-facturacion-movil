<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FerreteriaInventario.Maui.Views.ComprasPage"
             Title="Compras">
    <VerticalStackLayout Padding="20" Spacing="12">
        <Button Text="Nueva compra" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding NewCommand}" />
        <CollectionView ItemsSource="{Binding Compras}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Style="{StaticResource CardFrameStyle}" Margin="0,0,0,10">
                        <VerticalStackLayout>
                            <Label Text="{Binding NumeroFactura}" FontAttributes="Bold" />
                            <Label Text="{Binding ProveedorNombre}" />
                            <Label Text="{Binding Total, StringFormat='Total: {0:C}'}" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>
