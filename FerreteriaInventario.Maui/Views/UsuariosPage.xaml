<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FerreteriaInventario.Maui.Views.UsuariosPage"
             Title="Usuarios">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">
            <Frame Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Nuevo usuario" FontAttributes="Bold" />
                    <Entry Placeholder="Nombre" Text="{Binding Nombre}" />
                    <Entry Placeholder="Nombre de usuario" Text="{Binding NombreUsuario}" />
                    <Entry Placeholder="Correo" Text="{Binding Email}" />
                    <Entry Placeholder="Contrasena temporal" IsPassword="True" Text="{Binding Password}" />
                    <Picker Title="Rol" ItemsSource="{Binding Roles}" ItemDisplayBinding="{Binding Nombre}" SelectedItem="{Binding SelectedRol}" />
                    <Button Text="Crear usuario" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding CreateCommand}" />
                </VerticalStackLayout>
            </Frame>

            <CollectionView ItemsSource="{Binding Usuarios}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Style="{StaticResource CardFrameStyle}" Margin="0,0,0,10">
                            <VerticalStackLayout>
                                <Label Text="{Binding Nombre}" FontAttributes="Bold" />
                                <Label Text="{Binding NombreUsuario}" />
                                <Label Text="{Binding RolNombre}" TextColor="{StaticResource Secondary}" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
