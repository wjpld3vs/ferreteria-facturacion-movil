<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FerreteriaInventario.Maui.Views.LoginPage"
             Title="Login">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="18" VerticalOptions="Center">
            <Label Text="Ferreteria Inventario"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="{StaticResource Primary}" />
            <Label Text="Control de inventario, compras y ventas para operacion local."
                   TextColor="{StaticResource TextMuted}" />

            <Frame Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="14">
                    <Entry Placeholder="Usuario o correo"
                           x:Name="UsuarioEntry"
                           AutomationId="Login_UsuarioEntry"
                           Text="{Binding UsuarioOEmail}" />
                    <Entry Placeholder="Contrasena"
                           x:Name="PasswordEntry"
                           IsPassword="True"
                           AutomationId="Login_PasswordEntry"
                           Text="{Binding Password}" />
                    <Button Text="Iniciar sesion"
                            x:Name="SubmitButton"
                            AutomationId="Login_SubmitButton"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding LoginCommand}" />
                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       AutomationId="Login_Loader" />
                    <Label Text="{Binding ErrorMessage}"
                           x:Name="ErrorLabel"
                           AutomationId="Login_ErrorLabel"
                           TextColor="{StaticResource Danger}" />
                </VerticalStackLayout>
            </Frame>

            <Label Text="Credenciales de desarrollo: admin / Admin123* y operario / Operario123*"
                   FontSize="12"
                   TextColor="{StaticResource TextMuted}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
